  "keyFeatures": [
    "Multi-platform support (Node.js, Browser/WASM, Rust)",
    "Intel TDX attestation verification via Intel DCAP",
    "Configurable policy engine for TCB levels and measurements",
    "Session binding via EKM (RFC 9266)",
    "Bootchain and application configuration verification",
    "WebSocket-to-TCP proxy for browser deployments"
  ],
  "publicApiSurface": [
    "atls_connect() - High-level Rust API for TLS connection with attestation",
    "AtlsVerifier trait - Low-level trait for custom verifiers",
    "Policy enum - Configurable verification policies",
    "createAtlsFetch() - Node.js fetch-compatible API",
    "createAtlsAgent() - Node.js https.Agent for existing clients",
    "createAtlsFetch() - Browser/WASM fetch API",
    "AtlsHttp - WASM HTTP client with streaming",
    "AttestedStream - WASM low-level TLS stream",
    "DstackTDXVerifier - Intel TDX verifier implementation",
    "ExpectedBootchain - Bootchain measurement configuration"
  ]
}
